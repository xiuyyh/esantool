
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores core information about the marketplace users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "balance": { "type": "number", "description": "The user's current account balance in Naira." },
        "isAdmin": { "type": "boolean", "description": "Whether the user has administrative privileges." },
        "purchasedGroups": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of group IDs the user has purchased access to."
        },
        "cart": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of group IDs currently in the user's cart."
        }
      },
      "required": ["uid", "email"]
    },
    "TelegramGroup": {
      "title": "Telegram Group",
      "description": "A private Telegram group listing.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "country": { "type": "string" },
        "accessLink": { "type": "string", "description": "The actual private Telegram link." },
        "imageUrls": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Array of Base64 or URL strings for preview images."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "country", "accessLink"]
    },
    "Country": {
      "title": "Country",
      "description": "Region for sorting groups.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of a credit top-up request.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["credit"] }
      },
      "required": ["uid", "amount", "status"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global configuration for the platform.",
      "type": "object",
      "properties": {
        "telegramBotToken": { "type": "string" },
        "telegramChannelId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile records."
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/TelegramGroup" },
      "description": "Marketplace group listings."
    },
    "/countries/{countryId}": {
      "schema": { "$ref": "#/entities/Country" },
      "description": "Supported countries for sorting."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Top-up requests."
    },
    "/settings/admin": {
      "schema": { "$ref": "#/entities/AdminSettings" },
      "description": "Global settings."
    }
  }
}
