
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores core information about the marketplace users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "balance": { "type": "number", "description": "The user's current account balance in Naira." },
        "isAdmin": { "type": "boolean", "description": "Whether the user has administrative privileges." },
        "purchasedGroups": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of group IDs the user has purchased access to."
        },
        "purchasedSoftware": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of software IDs the user has purchased."
        },
        "cart": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of group or software IDs currently in the user's cart."
        },
        "referralCode": { "type": "string", "description": "Unique code for referring others." },
        "referredBy": { "type": "string", "description": "UID of the user who referred this person." },
        "referralEarnings": { "type": "number", "description": "Total Naira earned from referrals." }
      },
      "required": ["uid", "email"]
    },
    "TelegramGroup": {
      "title": "Telegram Group Bundle",
      "description": "A bundle containing one or more private Telegram links.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number", "description": "The base price set by admin." },
        "salesCount": { "type": "number", "description": "Total number of times this bundle has been purchased." },
        "country": { "type": "string" },
        "type": { "type": "string", "enum": ["bundle", "exclusive"], "description": "Exclusive items are hidden after first purchase." },
        "isSold": { "type": "boolean", "description": "Whether an exclusive item has been sold." },
        "links": {
          "type": "array",
          "description": "List of links included in this bundle.",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "Label for the link." },
              "url": { "type": "string", "description": "The actual Telegram invite URL." }
            },
            "required": ["label", "url"]
          }
        },
        "imageUrls": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Array of preview images."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "country", "links", "type"]
    },
    "Software": {
      "title": "Software Asset",
      "description": "Digital software listed in the marketplace.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "downloadUrl": { "type": "string", "description": "Manual setup required via support." },
        "version": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price"]
    },
    "Dispute": {
      "title": "Bundle Dispute",
      "description": "A claim filed by a user for a low-quality or junk bundle.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userEmail": { "type": "string" },
        "groupId": { "type": "string" },
        "groupTitle": { "type": "string" },
        "junkLinkName": { "type": "string", "description": "The specific label of the link identified as junk." },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "adminNote": { "type": "string", "description": "Reference note from the admin during resolution." },
        "resolutionLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "groupId", "status"]
    },
    "Country": {
      "title": "Country",
      "description": "Region for sorting groups.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of a credit top-up request.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["credit", "referral_bonus"] }
      },
      "required": ["uid", "amount", "status"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global configuration for the platform.",
      "type": "object",
      "properties": {
        "telegramBotToken": { "type": "string" },
        "telegramChannelId": { "type": "string" },
        "bundleReferralReward": { "type": "number", "description": "Referral bonus for bundle purchases." },
        "exclusiveReferralReward": { "type": "number", "description": "Referral bonus for exclusive purchases." },
        "softwareReferralReward": { "type": "number", "description": "Referral bonus for software purchases." }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Question for the public page.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number", "description": "Sort order for display." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "answer"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile records."
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/TelegramGroup" },
      "description": "Marketplace group listings."
    },
    "/software/{softwareId}": {
      "schema": { "$ref": "#/entities/Software" },
      "description": "Software marketplace listings."
    },
    "/countries/{countryId}": {
      "schema": { "$ref": "#/entities/Country" },
      "description": "Supported countries for sorting."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Top-up requests and bonuses."
    },
    "/disputes/{disputeId}": {
      "schema": { "$ref": "#/entities/Dispute" },
      "description": "Junk group compensation claims."
    },
    "/settings/admin": {
      "schema": { "$ref": "#/entities/AdminSettings" },
      "description": "Global settings."
    },
    "/faqs/{faqId}": {
      "schema": { "$ref": "#/entities/FAQ" },
      "description": "Public FAQs."
    }
  }
}
